{
    "extends": "@mino/typescript/next-react.json",
    "compilerOptions": {
        "baseUrl": ".",
        "allowArbitraryExtensions": true,
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": [
        "src",
        ".next/types/**/*.ts",
        "tests",
        "happydom.ts",
        "playwright.config.ts",
        "next.config.ts"
    ],
    "exclude": ["node_modules", ".next"]
}
