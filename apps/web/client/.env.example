# App environment
MINO_ENV=                             # development | test | production
NODE_ENV=                             # development | test | production

# Site
NEXT_PUBLIC_SITE_URL=                 # e.g. http://localhost:3000

# Supabase (production / development)
SUPABASE_DATABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase (test — used automatically when MINO_ENV=test)
TEST_SUPABASE_DATABASE_URL=
TEST_SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_TEST_SUPABASE_URL=
NEXT_PUBLIC_TEST_SUPABASE_PUBLISHABLE_KEY=

# GitHub App
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_APP_PRIVATE_KEY=

# CodeSandbox
CSB_API_KEY=                          # production / development
TEST_CSB_API_KEY=                     # used automatically when MINO_ENV=test

# Encryption Key (for githubAccessToken)
ENCRYPTION_KEY=